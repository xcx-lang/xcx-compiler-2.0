--- Returns the absolute value of a float.
func abs_f(f: x -> f) {
    if (x < 0.0) then;
        return -x;
    end;
    return x;
};

--- Returns the smaller of two floats.
func min_f(f: a, f: b -> f) {
    if (a < b) then; 
        return a; 
    end;
    return b;
};

--- Returns the larger of two floats.
func max_f(f: a, f: b -> f) {
    if (a > b) then; 
        return a; 
    end;
    return b;
};

--- Clamps val to the range [lo, hi].
func clamp_f(f: val, f: lo, f: hi -> f) {
    if (val < lo) then; 
        return lo; 
    end;
    if (val > hi) then; 
        return hi; 
    end;
    return val;
};

--- Returns 1, -1, or 0 depending on the sign of x.
func sign_f(f: x -> i) {
    if (x > 0.0) then; 
        return 1;  
    end;
    if (x < 0.0) then; 
        return -1; 
    end;
    return 0;
};

--- Returns the largest integer less than or equal to x.
func floor_f(f: x -> i) {
    i: n = i(x);
    if (x < 0.0 AND f(n) != x) then;
        return n - 1;
    end;
    return n;
};

--- Returns the smallest integer greater than or equal to x.
func ceil_f(f: x -> i) {
    i: n = i(x);
    if (x > 0.0 AND f(n) != x) then;
        return n + 1;
    end;
    return n;
};

--- Rounds x to the nearest integer.
func round_f(f: x -> i) {
    return floor_f(x + 0.5);
};

--- Returns the fractional part of x.
func frac(f: x -> f) {
    return x - f(i(x));
};

--- Linear interpolation: a + (b - a) * t
func lerp(f: a, f: b, f: t -> f) {
    return a + (b - a) * t;
};

--- Linear interpolation with t clamped to [0.0, 1.0].
func lerp_clamped(f: a, f: b, f: t -> f) {
    f: tc = clamp_f(t, 0.0, 1.0);
    return a + (b - a) * tc;
};

--- Returns true if |a - b| < epsilon.
func nearly_equal(f: a, f: b, f: epsilon -> b) {
    return abs_f(a - b) < epsilon;
};

