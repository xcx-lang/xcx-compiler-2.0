--- Raises an integer base to a non-negative integer exponent.
--- Uses fast exponentiation by squaring.
func pow_i(i: base, i: exp -> i) {
    if (exp < 0) then;
        halt.error >! "pow_i: negative exponent not allowed for integers";
        return 0;
    end;
    if (exp == 0) then; return 1; end;
    i: result = 1;
    i: e = exp;
    i: b = base;
    while (e > 0) do;
        if (e % 2 == 1) then;
            result = result * b;
        end;
        b = b * b;
        e = e / 2;
    end;
    return result;
};

--- Raises a float base to an integer exponent (positive or negative).
func pow_f(f: base, i: exp -> f) {
    if (exp == 0) then; return 1.0; end;
    b: neg = (exp < 0);
    i: e = abs_i(exp);
    f: result = 1.0;
    f: b = base;
    while (e > 0) do;
        if (e % 2 == 1) then;
            result = result * b;
        end;
        b = b * b;
        e = e / 2;
    end;
    if (neg) then;
        if (result == 0.0) then;
            halt.error >! "pow_f: division by zero (1 / 0)";
            return 0.0;
        end;
        return 1.0 / result;
    end;
    return result;
};

--- Returns the square root of x using Newton-Raphson iteration.
func sqrt_f(f: x -> f) {
    if (x < 0.0) then;
        halt.error >! "sqrt_f: square root of negative number";
        return -1.0;
    end;
    if (x == 0.0) then; return 0.0; end;
    f: guess = x / 2.0;
    i: iter = 0;
    while (iter < 50) do;
        f: next = (guess + x / guess) / 2.0;
        if (abs_f(next - guess) < 0.000000001) then;
            return next;
        end;
        guess = next;
        iter = iter + 1;
    end;
    return guess;
};

--- Returns the cube root of x (works for negative numbers too).
func cbrt_f(f: x -> f) {
    if (x == 0.0) then; return 0.0; end;
    f: s = 1.0;
    if (x < 0.0) then; s = -1.0; end;
    f: ax = abs_f(x);
    f: g = ax / 3.0;
    i: iter = 0;
    while (iter < 50) do;
        f: g3 = g * g * g;
        f: next = g - (g3 - ax) / (3.0 * g * g);
        if (abs_f(next - g) < 0.000000001) then;
            return s * next;
        end;
        g = next;
        iter = iter + 1;
    end;
    return s * g;
};

--- Returns the hypotenuse of a right triangle: sqrt(a^2 + b^2).
func hypot(f: a, f: b -> f) {
    return sqrt_f(a * a + b * b);
};

