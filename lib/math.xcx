--- Converts degrees to radians.
func deg_to_rad(f: deg -> f) {
    return deg * PI / 180.0;
};

--- Converts radians to degrees.
func rad_to_deg(f: rad -> f) {
    return rad * 180.0 / PI;
};

--- Returns the sine of x (radians) via Taylor series.
func sin_f(f: x -> f) {
    f: v = x;
    while (v > PI)  do; v = v - TAU; end;
    while (v < -PI) do; v = v + TAU; end;
    f: result = v;
    f: term   = v;
    i: n      = 1;
    while (n < 20) do;
        term = -term * v * v / f(2 * n) / f(2 * n + 1);
        result = result + term;
        n = n + 1;
    end;
    return result;
};

--- Returns the cosine of x (radians).
func cos_f(f: x -> f) {
    return sin_f(x + PI / 2.0);
};

--- Returns the tangent of x (radians).
func tan_f(f: x -> f) {
    f: c = cos_f(x);
    if (abs_f(c) < 0.000000001) then;
        halt.error >! "tan_f: tangent undefined (cosine is zero)";
        return 0.0;
    end;
    return sin_f(x) / c;
};

--- Returns the arctangent of x in radians.
func atan_f(f: x -> f) {
    if (x > 1.0)  then; return PI / 2.0  - atan_f(1.0 / x); end;
    if (x < -1.0) then; return -PI / 2.0 - atan_f(1.0 / x); end;
    f: x2     = x * x;
    f: result = x;
    f: term   = x;
    i: n      = 1;
    while (n < 50) do;
        term = -term * x2;
        result = result + term / f(2 * n + 1);
        n = n + 1;
    end;
    return result;
};

--- Returns the angle (radians) of the point (x, y) from the positive x-axis.
func atan2_f(f: y, f: x -> f) {
    if (x > 0.0)               then; return atan_f(y / x);          end;
    if (x < 0.0 AND y >= 0.0)  then; return atan_f(y / x) + PI;     end;
    if (x < 0.0 AND y < 0.0)   then; return atan_f(y / x) - PI;     end;
    if (x == 0.0 AND y > 0.0)  then; return PI / 2.0;               end;
    if (x == 0.0 AND y < 0.0)  then; return -PI / 2.0;              end;
    halt.error >! "atan2_f: both arguments are zero";
    return 0.0;
};

--- Returns the arcsine of x in radians. x must be in [-1, 1].
func asin_f(f: x -> f) {
    if (x < -1.0 OR x > 1.0) then;
        halt.error >! "asin_f: argument out of range [-1, 1]";
        return 0.0;
    end;
    return atan_f(x / sqrt_f(1.0 - x * x));
};

--- Returns the arccosine of x in radians. x must be in [-1, 1].
func acos_f(f: x -> f) {
    if (x < -1.0 OR x > 1.0) then;
        halt.error >! "acos_f: argument out of range [-1, 1]";
        return 0.0;
    end;
    return PI / 2.0 - asin_f(x);
};

--- Hyperbolic sine.
func sinh_f(f: x -> f) {
    return (exp_f(x) - exp_f(-x)) / 2.0;
};

--- Hyperbolic cosine.
func cosh_f(f: x -> f) {
    return (exp_f(x) + exp_f(-x)) / 2.0;
};

--- Hyperbolic tangent.
func tanh_f(f: x -> f) {
    f: e2 = exp_f(2.0 * x);
    return (e2 - 1.0) / (e2 + 1.0);
};

