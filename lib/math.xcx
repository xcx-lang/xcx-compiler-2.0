--- Returns the absolute value of an integer.
func abs_i(i: x -> i) {
    if (x < 0) then;
        return -x;
    end;
    return x;
};

--- Returns the smaller of two integers.
func min_i(i: a, i: b -> i) {
    if (a < b) then; 
        return a; 
    end;
    return b;
};

--- Returns the larger of two integers.
func max_i(i: a, i: b -> i) {
    if (a > b) then;
        return a;
    end;
    return b;
};

--- Clamps val to the range [lo, hi].
func clamp_i(i: val, i: lo, i: hi -> i) {
    if (val < lo) then; 
        return lo; 
    end;
    if (val > hi) then; 
        return hi; 
    end;
    return val;
};

--- Returns 1, -1, or 0 depending on the sign of x.
func sign_i(i: x -> i) {
    if (x > 0) then; 
        return 1;  
    end;
    if (x < 0) then; 
        return -1; 
    end;
    return 0;
};

