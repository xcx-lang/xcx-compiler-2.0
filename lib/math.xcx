--- Returns e raised to the power x, computed via Taylor series.
func exp_f(f: x -> f) {
    f: result = 1.0;
    f: term   = 1.0;
    i: n      = 1;
    while (n < 100) do;
        term = term * x / f(n);
        result = result + term;
        if (abs_f(term) < 0.0000000000001) then;
            return result;
        end;
        n = n + 1;
    end;
    return result;
};

--- Returns the natural logarithm of x.
func ln_f(f: x -> f) {
    if (x <= 0.0) then;
        halt.error >! "ln_f: logarithm of non-positive number";
        return 0.0;
    end;
    i: k = 0;
    f: v = x;
    while (v >= E) do;
        v = v / E;
        k = k + 1;
    end;
    while (v < 1.0) do;
        v = v * E;
        k = k - 1;
    end;
    f: t      = v - 1.0;
    f: result = 0.0;
    f: term   = t;
    i: n      = 1;
    while (n < 200) do;
        if (n % 2 == 1) then;
            result = result + term / f(n);
        else;
            result = result - term / f(n);
        end;
        term = term * t;
        if (abs_f(term) < 0.0000000000001) then;
            return f(k) + result;
        end;
        n = n + 1;
    end;
    return f(k) + result;
};

--- Returns the base-2 logarithm of x.
func log2_f(f: x -> f) {
    return ln_f(x) / LN2;
};

--- Returns the base-10 logarithm of x.
func log10_f(f: x -> f) {
    return ln_f(x) / LN10;
};

--- Returns the logarithm of x in a given base.
func log_base(f: x, f: base -> f) {
    if (base <= 0.0 OR base == 1.0) then;
        halt.error >! "log_base: invalid logarithm base";
        return 0.0;
    end;
    return ln_f(x) / ln_f(base);
};

