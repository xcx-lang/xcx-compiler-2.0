--- Returns the greatest common divisor of a and b (Euclidean algorithm).
func gcd(i: a, i: b -> i) {
    i: x = abs_i(a);
    i: y = abs_i(b);
    while (y != 0) do;
        i: t = y;
        y = x % y;
        x = t;
    end;
    return x;
};

--- Returns the least common multiple of a and b.
func lcm(i: a, i: b -> i) {
    if (a == 0 OR b == 0) then; return 0; end;
    return abs_i(a / gcd(a, b) * b);
};

--- Returns true if n is a prime number.
func is_prime(i: n -> b) {
    if (n < 2)       then; return false; end;
    if (n == 2)      then; return true;  end;
    if (n % 2 == 0)  then; return false; end;
    i: k = 3;
    while (k * k <= n) do;
        if (n % k == 0) then; return false; end;
        k = k + 2;
    end;
    return true;
};

--- Returns n! (iterative, avoids recursion depth limits).
func factorial(i: n -> i) {
    if (n < 0) then;
        halt.error >! "factorial: negative argument";
        return -1;
    end;
    if (n == 0 OR n == 1) then; return 1; end;
    i: result = 1;
    i: k = 2;
    while (k <= n) do;
        result = result * k;
        k = k + 1;
    end;
    return result;
};

--- Returns the n-th Fibonacci number (iterative).
func fibonacci(i: n -> i) {
    if (n < 0) then;
        halt.error >! "fibonacci: negative argument";
        return -1;
    end;
    if (n == 0) then; return 0; end;
    if (n == 1) then; return 1; end;
    i: a = 0;
    i: b = 1;
    i: k = 2;
    while (k <= n) do;
        i: tmp = a + b;
        a = b;
        b = tmp;
        k = k + 1;
    end;
    return b;
};

--- Returns C(n, k) — binomial coefficient "n choose k".
func combinations(i: n, i: k -> i) {
    if (k < 0 OR k > n) then; return 0; end;
    if (k == 0 OR k == n) then; return 1; end;
    i: kk = k;
    if (n - k < k) then; kk = n - k; end;
    i: result = 1;
    i: j = 0;
    while (j < kk) do;
        result = result * (n - j) / (j + 1);
        j = j + 1;
    end;
    return result;
};

--- Returns P(n, k) — number of k-permutations of n elements.
func permutations(i: n, i: k -> i) {
    if (k < 0 OR k > n) then; return 0; end;
    i: result = 1;
    i: j = 0;
    while (j < k) do;
        result = result * (n - j);
        j = j + 1;
    end;
    return result;
};

--- Returns true if n is even.
func is_even(i: n -> b) {
    return n % 2 == 0;
};

--- Returns true if n is odd.
func is_odd(i: n -> b) {
    return n % 2 != 0;
};

--- Returns true if n is divisible by d.
func is_divisible(i: n, i: d -> b) {
    if (d == 0) then;
        halt.error >! "is_divisible: divisor is zero";
        return false;
    end;
    return n % d == 0;
};

--- Returns the sum of all decimal digits of n.
func digits_sum(i: n -> i) {
    i: v = abs_i(n);
    i: s = 0;
    while (v > 0) do;
        s = s + v % 10;
        v = v / 10;
    end;
    return s;
};

--- Returns the number of decimal digits in n.
func count_digits(i: n -> i) {
    if (n == 0) then; return 1; end;
    i: v = abs_i(n);
    i: c = 0;
    while (v > 0) do;
        v = v / 10;
        c = c + 1;
    end;
    return c;
};

--- Returns the integer with its digits reversed (e.g. 123 -> 321).
func reverse_int(i: n -> i) {
    b: neg = (n < 0);
    i: v = abs_i(n);
    i: r = 0;
    while (v > 0) do;
        r = r * 10 + v % 10;
        v = v / 10;
    end;
    if (neg) then; return -r; end;
    return r;
};

--- Returns true if n reads the same forwards and backwards.
func is_palindrome_int(i: n -> b) {
    if (n < 0) then; return false; end;
    return n == reverse_int(n);
};

