--- Returns the sum of all elements in an float array.
func sum_arr(array:f: arr -> f) {
    f: s = 0.0;
    i: k = 0;
    i: sz = arr.size();
    while (k < sz) do;
        f: val = arr.get(k);
        s = s + val;
        k = k + 1;
    end;
    return s;
};

--- Returns the sum of all elements in an integer array.
func sum_arr_i(array:i: arr -> i) {
    i: s = 0;
    i: k = 0;
    while (k < arr.size()) do;
        s = s + arr.get(k);
        k = k + 1;
    end;
    return s;
};

--- Returns the arithmetic mean of the array.
func mean(array:f: arr -> f) {
    i: n = arr.size();
    if (n == 0) then;
        halt.error >! "mean: empty array";
        return 0.0;
    end;
    f: s = sum_arr(arr);
    f: result = s / f(n);
    return result;
};

--- Returns the population variance of the array.
func variance(array:f: arr -> f) {
    i: n = arr.size();
    if (n < 2) then;
        halt.error >! "variance: at least 2 elements required";
        return 0.0;
    end;
    f: m   = mean(arr);
    f: acc = 0.0;
    i: k   = 0;
    while (k < n) do;
        f: diff = arr.get(k) - m;
        acc = acc + diff * diff;
        k = k + 1;
    end;
    return acc / f(n);
};

--- Returns the population standard deviation of the array.
func std_dev(array:f: arr -> f) {
    return sqrt_f(variance(arr));
};

--- Returns the minimum value in the array.
func min_arr(array:f: arr -> f) {
    i: n = arr.size();
    if (n == 0) then;
        halt.error >! "min_arr: empty array";
        return 0.0;
    end;
    f: m = arr.get(0);
    i: k = 1;
    while (k < n) do;
        f: v = arr.get(k);
        if (v < m) then; m = v; end;
        k = k + 1;
    end;
    return m;
};

--- Returns the maximum value in the array.
func max_arr(array:f: arr -> f) {
    i: n = arr.size();
    if (n == 0) then;
        halt.error >! "max_arr: empty array";
        return 0.0;
    end;
    f: m = arr.get(0);
    i: k = 1;
    while (k < n) do;
        f: v = arr.get(k);
        if (v > m) then; m = v; end;
        k = k + 1;
    end;
    return m;
};

--- Returns max - min of the array.
func range_arr(array:f: arr -> f) {
    return max_arr(arr) - min_arr(arr);
};

--- Returns the median of the array (sorts a copy in-place).
func median(array:f: arr -> f) {
    i: n = arr.size();
    if (n == 0) then;
        halt.error >! "median: empty array";
        return 0.0;
    end;
    arr.sort();
    if (n % 2 == 1) then;
        return arr.get(n / 2);
    end;
    return (arr.get(n / 2 - 1) + arr.get(n / 2)) / 2.0;
};

--- Returns the dot product of two equal-length float arrays.
func dot_product(array:f: a, array:f: b -> f) {
    if (a.size() != b.size()) then;
        halt.error >! "dot_product: arrays must have equal length";
        return 0.0;
    end;
    f: s = 0.0;
    i: k = 0;
    while (k < a.size()) do;
        s = s + a.get(k) * b.get(k);
        k = k + 1;
    end;
    return s;
};

--- Returns the Euclidean norm (magnitude) of a vector.
func norm_vec(array:f: v -> f) {
    return sqrt_f(dot_product(v, v));
};

