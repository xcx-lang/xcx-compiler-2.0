const f: PI      = 3.14159265358979;   --- ratio of circumference to diameter
const f: E       = 2.71828182845905;   --- Euler's number
const f: TAU     = 6.28318530717959;   --- 2 * PI
const f: PHI     = 1.61803398874989;   --- golden ratio
const f: SQRT2   = 1.41421356237310;   --- square root of 2
const f: LN2     = 0.69314718055995;   --- natural log of 2
const f: LN10    = 2.30258509299405;   --- natural log of 10
const f: INF     = 999999999999999.0;  --- practical infinity approximation
const i: INT_MAX = 2147483647;
const i: INT_MIN = -2147483648;

