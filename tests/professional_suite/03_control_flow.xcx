
i: x = 10;
if (x > 15) then;
    halt.error >! "Should not be here";
elseif (x > 5) then;
    >! "X is moderate (expected)";
else;
    halt.error >! "Should not be here";
end;


i: sum = 0;
for i in 1 to 5 do;
    sum = sum + i;
end;
if (sum != 15) then;
    halt.error >! "For loop 1 to 5 sum failed";
end;

i: even_sum = 0;
for j in 0 to 10 @step 2 do;
    even_sum = even_sum + j;
end;

if (even_sum != 30) then;
    halt.error >! "For loop with @step 2 failed";
end;

i: count = 5;
i: w_sum = 0;
while (count > 0) do;
    w_sum = w_sum + count;
    count = count - 1;
end;
if (w_sum != 15) then;
    halt.error >! "While loop failed";
end;


i: b_sum = 0;
for k in 1 to 10 do;
    if (k == 6) then; break; end;
    if (k % 2 == 0) then; continue; end;
    b_sum = b_sum + k;
end;

if (b_sum != 9) then;
    halt.error >! "Break/Continue test failed";
end;

>! "Control Flow test passed";
