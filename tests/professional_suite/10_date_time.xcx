--- 10_date_time.xcx
--- Testing date type and its methods according to Spec Section 16.

date: d1 = date("2024-03-15");
date: today = date.now();

--- Properties
if (d1.year != 2024) then;
    halt.error >! "Date.year failed";
end;
if (d1.month != 3) then;
    halt.error >! "Date.month failed";
end;
if (d1.day != 15) then;
    halt.error >! "Date.day failed";
end;

--- Arithmetic
date: d2 = d1 + 10;
if (d2.day != 25) then;
    halt.error >! "Date + days failed";
end;

date: d3 = d2 - 10;
if (d3 != d1) then;
    halt.error >! "Date - days failed";
end;

i: diff = d2 - d1;
if (diff != 10) then;
    halt.error >! "Date subtraction (diff) failed";
end;

--- Comparison
if (!(d2 > d1)) then;
    halt.error >! "Date comparison > failed";
end;
if (!(d1 == d1)) then;
    halt.error >! "Date equality failed";
end;

--- Formatting
s: f1 = d1.format();
if (f1 != "2024-03-15") then;
    halt.error >! "Date format default failed";
end;

s: f2 = d1.format("DD/MM/YYYY");
if (f2 != "15/03/2024") then;
    halt.error >! "Date format custom failed";
end;

>! "Date and Time test passed";
