--- Fiber Return Test: return expr; in typed fiber

fiber generator(i: max -> i) {
    for i in 1 to max do;
        if (i == 3) then;
            return 99;
        end;
        yield i;
    end;
};

fiber:i: f = generator(5);

>! f.next(); --- should be 1
>! f.next(); --- should be 2
>! f.next(); --- should be 99

if (f.isDone()) then;
    >! "DONE: PASSED";
else;
    >! "DONE: FAILED";
end;
