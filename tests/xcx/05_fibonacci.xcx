
func fib(i: n -> i) {
    if (n <= 1) then;
        return n;
    end;
    return fib(n - 1) + fib(n - 2);
};

i: f0 = fib(0);
>! "fib(0) = " + f0;

i: f1 = fib(1);
>! "fib(1) = " + f1;

i: f5 = fib(5);
>! "fib(5) = " + f5;

i: f10 = fib(10);
>! "fib(10) = " + f10;

i: f15 = fib(15);
>! "fib(15) = " + f15;

i: f20 = fib(20);
>! "fib(20) = " + f20;
