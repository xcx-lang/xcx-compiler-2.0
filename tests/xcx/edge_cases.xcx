--- ============================================================
--- 13. SETS
--- ============================================================

>! "--- 13. SETS ---";

--- Natural number range
set:N: small {1,,5};
>! "set N {1..5} size (expect 5): " + small.size();
>! "contains 3 (expect true):  " + small.contains(3);
>! "contains 9 (expect false): " + small.contains(9);

--- Explicit integer set
set:Z: zset {-2, -1, 0, 1, 2};
>! "Z set size (expect 5): " + zset.size();

--- String set (uniqueness enforced)
set:S: names {"Alice", "Bob", "Alice", "Charlie"};
>! "S set size (expect 3, Alice deduped): " + names.size();

--- Set operations
set:N: setA {1,,5};
set:N: setB {3,,7};
set:N: u = setA UNION setB;
set:N: inter = setA INTERSECTION setB;
set:N: diff = setA DIFFERENCE setB;
>! "union {1..5} ∪ {3..7} size (expect 7): " + u.size();
>! "inter {1..5} ∩ {3..7} size (expect 3): " + inter.size();
>! "diff  {1..5} \\ {3..7} size (expect 2): " + diff.size();

--- Random choice from set (just test it doesn't crash)
set:N: choices {10, 20, 30};
i: picked = random.choice from choices;
>! "random.choice from {10,20,30} (any value): " + picked;


--- ============================================================
--- 14. MAPS
--- ============================================================

>! "--- 14. MAPS ---";

map: ages {
    schema = [s <-> i]
    data = [
        "alice" :: 30,
        "bob"   :: 25
    ]
};

>! "ages.size (expect 2): " + ages.size();
>! "ages.get('alice') (expect 30): " + ages.get("alice");
>! "ages.contains('bob') (expect true):  " + ages.contains("bob");
>! "ages.contains('eve') (expect false): " + ages.contains("eve");

--- Insert updates existing key
ages.insert("charlie", 40);
>! "after insert charlie (expect 3): " + ages.size();

--- Empty map
map: empty_map {
    schema = [i <-> s]
    data = [EMPTY]
};
>! "empty map size (expect 0): " + empty_map.size();


--- ============================================================
--- 15. TABLES
--- ============================================================

>! "--- 15. TABLES ---";

table: products {
    columns = [
        id   :: i @auto,
        name :: s,
        price :: f
    ]
    rows = [
        ("Laptop", 2999.99),
        ("Phone",  1499.50),
        ("Mouse",    79.99)
    ]
};

>! "products.count (expect 3): " + products.count();
>! "products[0].name (expect Laptop): " + products[0].name;
>! "products[1].name (expect Phone):  " + products[1].name;
>! "products[2].name (expect Mouse):  " + products[2].name;

--- Insert a new row
products.insert("Keyboard", 149.99);
>! "after insert count (expect 4): " + products.count();
>! "products[3].name (expect Keyboard): " + products[3].name;

--- Delete
products.delete(3);
>! "after delete count (expect 3): " + products.count();

--- Filtering
table: expensive = products.where(price > 1000);
>! "expensive rows (expect 2): " + expensive.count();

--- Empty table
table: orders {
    columns = [
        order_id :: i @auto,
        qty      :: i
    ]
    rows = [EMPTY]
};
>! "empty orders (expect 0): " + orders.count();

--- Insert into empty table
orders.insert(5);
>! "orders after insert (expect 1): " + orders.count();


