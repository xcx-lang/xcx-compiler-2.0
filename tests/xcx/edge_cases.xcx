i: a = 10;
i: b = 3;
>! "10 + 3 (expect 13): " + (a + b);
>! "10 - 3 (expect  7): " + (a - b);
>! "10 * 3 (expect 30): " + (a * b);
>! "10 / 3 (expect  3): " + (a / b);
>! "10 % 3 (expect  1): " + (a % b);
>! "10 ^ 3 (expect 1000): " + (a ^ b);

--- Integer concatenation (++)
i: phone = 48 ++ 777;
>! "48 ++ 777 (expect 48777): " + phone;


--- ============================================================
--- 3. ARITHMETIC — FLOAT
--- ============================================================

>! "--- 3. FLOAT ARITHMETIC ---";
f: x = 5.5;
f: y = 2.0;
>! "5.5 + 2.0 (expect 7.5): " + (x + y);
>! "5.5 - 2.0 (expect 3.5): " + (x - y);
>! "5.5 * 2.0 (expect 11.0): " + (x * y);
>! "5.5 / 2.0 (expect 2.75): " + (x / y);


--- ============================================================
--- 4. UNARY NEGATION — BUG FIX EDGE CASE
--- ============================================================

>! "--- 4. UNARY NEGATION ---";
i: neg_int = -7;
f: neg_float = -3.14;
>! "neg int (expect -7): " + neg_int;
>! "neg float (expect -3.14): " + neg_float;

--- Negation in expression context
i: pos = 5;
i: neg_expr = -5;
>! "5 + (-5) (expect 0): " + (pos + neg_expr);

--- Negation of variable (via 0 - var)
i: val = 42;
i: negated = 0 - val;
>! "0 - 42 (expect -42): " + negated;


--- ============================================================
--- 5. STRING OPERATIONS
--- ============================================================

>! "--- 5. STRINGS ---";
s: hello = "Hello";
s: world = "World";
s: combined = hello + ", " + world + "!";
>! "concat (expect 'Hello, World!'): " + combined;

--- HAS operator
b: has_comma = combined HAS ",";
b: no_x = combined HAS "XYZ";
>! "has comma (expect true): " + has_comma;
>! "has XYZ (expect false): " + no_x;

--- String + int coercion in print
i: num = 42;
>! "num in string (expect 'Answer: 42'): Answer: " + num;


--- ============================================================
--- 6. BOOLEAN LOGIC
--- ============================================================

>! "--- 6. BOOLEANS ---";
b: t = true;
b: f_val = false;
>! "true AND true   (expect true):  " + (t AND t);
>! "true AND false  (expect false): " + (t AND f_val);
>! "false OR true   (expect true):  " + (f_val OR t);
>! "false OR false  (expect false): " + (f_val OR f_val);
>! "NOT true        (expect false): " + (NOT t);
>! "NOT false       (expect true):  " + (NOT f_val);

--- Short-circuit equivalents with symbols
>! "true && false   (expect false): " + (t && f_val);
>! "false || true   (expect true):  " + (f_val || t);


--- ============================================================
--- 7. COMPARISONS
--- ============================================================

>! "--- 7. COMPARISONS ---";
i: p = 10;
i: q = 20;
>! "10 == 10 (expect true):  " + (p == p);
>! "10 != 20 (expect true):  " + (p != q);
>! "10 <  20 (expect true):  " + (p < q);
>! "10 >  20 (expect false): " + (p > q);
>! "10 <= 10 (expect true):  " + (p <= p);
>! "20 >= 10 (expect true):  " + (q >= p);


--- ============================================================
--- 8. IF / ELSEIF / ELSE
--- ============================================================

>! "--- 8. CONTROL FLOW ---";
i: score = 75;

if (score >= 90) then;
    >! "Grade: A";
elseif (score >= 75) then;
    >! "Grade: B  (expect this)";
elseif (score >= 60) then;
    >! "Grade: C";
else;
    >! "Grade: F";
end;

--- Nested if
b: admin = true;
b: active_user = true;
if (admin AND active_user) then;
    >! "Admin active (expect this)";
else;
    >! "Not admin active";
end;

--- Edge: if condition false at boundary
i: boundary = 0;
if (boundary > 0) then;
    >! "FAIL: should not print";
else;
    >! "boundary == 0 — correct";
end;


--- ============================================================
--- 9. FOR LOOPS
--- ============================================================

>! "--- 9. FOR LOOPS ---";

--- Basic range (1 to 3)
>! "Range 1..3:";
for i in 1 to 3 do;
    >! "  i = " + i;
end;

--- With step
>! "Even 0..6 step 2:";
for j in 0 to 6 @step 2 do;
    >! "  j = " + j;
end;

--- Single iteration (start == end)
>! "Single iter (5..5):";
for k in 5 to 5 do;
    >! "  k = " + k;
end;


--- ============================================================
--- 10. WHILE LOOPS + BREAK + CONTINUE
--- ============================================================

>! "--- 10. WHILE / BREAK / CONTINUE ---";

--- Basic while
i: cnt = 0;
while (cnt < 3) do;
    cnt = cnt + 1;
    >! "cnt = " + cnt;
end;
>! "after while (expect 3): " + cnt;

--- Break
i: brk = 0;
while (brk < 100) do;
    brk = brk + 1;
    if (brk == 3) then;
        break;
    end;
end;
>! "break at 3 (expect 3): " + brk;

--- Continue (skip even numbers, count to 5)
>! "Odd numbers 1..5 via continue:";
for n in 1 to 5 do;
    if (n % 2 == 0) then;
        continue;
    end;
    >! "  " + n;
end;


--- ============================================================
--- 11. FUNCTIONS
--- ============================================================

>! "--- 11. FUNCTIONS ---";

--- No return type
func greet(s: who) {
    >! "Hello, " + who + "!";
};
greet("Alice");
greet("Bob");

--- With return type
func add(i: x, i: y -> i) {
    return x + y;
};
>! "add(3,4) (expect 7): " + add(3, 4);

--- Multiple params, float return
func average(f: u, f: v -> f) {
    return (u + v) / 2.0;
};
>! "avg(3.0,7.0) (expect 5.0): " + average(3.0, 7.0);

--- Recursion
func factorial(i: n -> i) {
    if (n <= 1) then;
        return 1;
    else;
        return n * factorial(n - 1);
    end;
};
>! "5! (expect 120): " + factorial(5);
>! "0! (expect 1):   " + factorial(0);

--- Fibonacci
func fib(i: n -> i) {
    if (n <= 0) then;
        return 0;
    elseif (n == 1) then;
        return 1;
    else;
        return fib(n - 1) + fib(n - 2);
    end;
};
>! "fib(6) (expect 8): " + fib(6);
>! "fib(1) (expect 1): " + fib(1);
>! "fib(0) (expect 0): " + fib(0);


