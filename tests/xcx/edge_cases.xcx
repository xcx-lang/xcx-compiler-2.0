
--- Default initialization (no value given → defaults)
i: def_int;
f: def_float;
s: def_str;
b: def_bool;
>! "--- 1. PRIMITIVES ---";
>! "def_int (expect 0): " + def_int;
>! "def_float (expect 0): " + def_float;
>! "def_str (expect empty): '" + def_str + "'";
>! "def_bool (expect false): " + def_bool;

--- Normal assignment
i: age = 25;
f: pi = 3.14159;
s: name = "XCX";
b: ok = true;
age = 26;
>! "age after reassign (expect 26): " + age;

--- Constants
const i: MAX = 100;
>! "MAX (expect 100): " + MAX;


