--- Arithmetic
date: day_after = christmas + 1;
>! "day after christmas day (expect 26): " + day_after.day;

date: day_before = christmas - 1;
>! "day before christmas day (expect 24): " + day_before.day;

--- Difference
date: new_year = date("2025-01-01");
i: days_gap = new_year - christmas;
>! "new_year - christmas (expect 7): " + days_gap;

--- Comparison
b: before_ny = (christmas < new_year);
>! "christmas < new_year (expect true): " + before_ny;

--- Custom format creation
date: custom = date("25/12/2024", "DD/MM/YYYY");
>! "custom date year (expect 2024): " + custom.year;


--- ============================================================
--- 17. HALT.ALERT (non-fatal — program continues)
--- ============================================================

>! "--- 17. HALT.ALERT (program must continue) ---";
halt.alert >! "This is a warning — program continues";
>! "Line after halt.alert (expect this to print)";


--- ============================================================
--- 18. HALT.ERROR (stops current frame — in function)
--- ============================================================

>! "--- 18. HALT.ERROR in function (frame stops, caller continues) ---";

func safe_div(i: num, i: divisor -> i) {
    if (divisor == 0) then;
        halt.error >! "Division by zero in safe_div";
        return -1;
    end;
    return num / divisor;
};

i: ok_result = safe_div(10, 2);
>! "safe_div(10,2) (expect 5): " + ok_result;

--- When divisor is 0, halt.error stops the frame; caller gets halt value
--- (the function returns without the return statement executing)
>! "Calling safe_div(10,0) — halt.error inside function:";
i: r2 = safe_div(10, 0);
>! "After call (program continues even though safe_div errored)";


