--- ============================================================
--- 20. NESTED LOOPS AND BREAK/CONTINUE INTERACTION
--- ============================================================

>! "--- 20. NESTED LOOPS ---";
i: outer_sum = 0;
for oi in 1 to 3 do;
    for oj in 1 to 3 do;
        if (oj == 2) then;
            continue;
        end;
        outer_sum = outer_sum + 1;
    end;
end;
--- Each outer iter contributes 2 (j=1 and j=3; j=2 is skipped)
>! "outer_sum (expect 6): " + outer_sum;

--- Break in inner loop
i: break_sum = 0;
for bi in 1 to 3 do;
    for bj in 1 to 10 do;
        if (bj > 2) then;
            break;
        end;
        break_sum = break_sum + 1;
    end;
end;
>! "break_sum (expect 6): " + break_sum;


