--- tests/xcx/recent_features.xcx
--- Tests for indexOf, lastIndexOf, .size() alias, and JSON integer indexing.

--- String methods
s: s_val = "hello world";
assert(s_val.indexOf("o") == 4);
assert(s_val.indexOf("z") == -1);
assert(s_val.lastIndexOf("o") == 7);
assert(s_val.lastIndexOf("x") == -1);

array:i: nums {1, 2, 3, 4, 5};
assert(nums.size() == 5);

set:N: st_val {1, 2, 3};
assert(st_val.size() == 3);

s: json_str = "[10, 20, 30]";
json: j = json.parse(json_str);

assert(j.get(0) == 10);
assert(j.get(1) == 20);
assert(j.get(2) == 30);

--- JSON size alias
assert(j.size() == 3);

>! "Recent features tests passed!";
