---=============================================================================
--- 05. LOOPS & BREAKS
--- VALIDATES: for to @step, while, break, continue
---=============================================================================

>! "Testing Loops & Breaks...";

i: sum = 0;
for i in 1 to 5 do;
    sum = sum + i;
end;

if (sum == 15) then;
    >! "Basic For loop: OK";
else;
    halt.error >! "Basic For loop logic: FAILED (" + sum + ")";
end;

i: step_sum = 0;
for j in 0 to 10 @step 2 do;
    step_sum = step_sum + j;
end;

if (step_sum == 30) then; --- 0 + 2 + 4 + 6 + 8 + 10
    >! "For loop @step: OK";
else;
    halt.error >! "For loop @step logic: FAILED (" + step_sum + ")";
end;

i: w_cnt = 0;
while (w_cnt < 10) do;
    w_cnt = w_cnt + 1;
    if (w_cnt == 5) then; continue; end;
    if (w_cnt == 8) then; break; end;
end;

if (w_cnt == 8) then;
    >! "While/Break/Continue: OK";
else;
    halt.error >! "While flow: FAILED (" + w_cnt + ")";
end;

>! "05. LOOPS & BREAKS: SUCCESS";
